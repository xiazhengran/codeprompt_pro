# ===========================================
# LLM 提供商配置
# ===========================================

# OpenAI (默认)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Anthropic Claude (可选)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# Azure OpenAI (可选)
AZURE_OPENAI_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# 本地模型 - Ollama (可选)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# 本地模型 - LM Studio (可选)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_TEMPERATURE=0.7
LM_STUDIO_MAX_TOKENS=4096

# ===========================================
# Agent 默认模型配置
# ===========================================

# 代码生成 Agent
CODE_AGENT_PROVIDER=openai
CODE_AGENT_MODEL=gpt-4
CODE_AGENT_TEMPERATURE=0.3

# 代码审查 Agent
REVIEW_AGENT_PROVIDER=openai
REVIEW_AGENT_MODEL=gpt-4
REVIEW_AGENT_TEMPERATURE=0.5

# 测试生成 Agent
TEST_AGENT_PROVIDER=openai
TEST_AGENT_MODEL=gpt-4
TEST_AGENT_TEMPERATURE=0.3

# 调试 Agent
DEBUG_AGENT_PROVIDER=openai
DEBUG_AGENT_MODEL=gpt-4
DEBUG_AGENT_TEMPERATURE=0.2

# 设计 Agent
DESIGN_AGENT_PROVIDER=openai
DESIGN_AGENT_MODEL=gpt-4
DESIGN_AGENT_TEMPERATURE=0.6

# 文档 Agent
DOC_AGENT_PROVIDER=openai
DOC_AGENT_MODEL=gpt-3.5-turbo
DOC_AGENT_TEMPERATURE=0.5

# ===========================================
# 应用配置
# ===========================================

APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000

# 可选：代理配置 (用于企业环境)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# 可选：速率限制
RATE_LIMIT_PER_MINUTE=60

# 可选：内存管理
MEMORY_MAX_TOKENS=100000
MEMORY_SUMMARY_THRESHOLD=5000
